@inherits Custom.Hybrid.RazorTyped
@using AppCode.Extensions.Angular

@{
  var ngHelper = GetService<Angular>();
  var angularAppTag = MyModel.String("AngularAppTag");

  var localDevServer = MyModel.String("LocalDevServerPath");
  var localFiles = MyModel.String("LocalDevFiles").Split(',');
}

@Html.Raw(ngHelper.GetLocalDevTag(angularAppTag, localDevServer))
@foreach (var file in localFiles)
{
  <script src="@localDevServer/@file" type="module"></script>
}
<link rel="stylesheet" href="@localDevServer/styles.css">