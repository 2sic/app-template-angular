@inherits Custom.Hybrid.RazorTyped
@using AppCode.Extensions.JsAppEditions
@using AppCode.Extensions.Angular
@using ToSic.Sxc.Services;
@using ToSic.Razor.Blade;

@{
  var editions = MyModel.String("Editions", fallback: "");
  var angularAppPath = MyModel.String("AngularAppPath");
  var angularAppTag = MyModel.String("AngularAppTag");
  var angularLocalDevServerPath = MyModel.String("LocalDevServerPath", fallback: "");
  var angularLocalDevFiles = MyModel.String("LocalDevFiles", fallback: "");

  // Enable 2sic JS APIs (this will load the latest js-api to help with getting data from 2sxc data base)
  Kit.Page.Activate("2sxc.JsCore");

  // Add <base> tag using RazorBlade - TODO: Check if needed
  Kit.Page.SetBase((Link.Base()));

  // Create helper to manage the editions (live, staging etc.)
  var editionsHelper = GetService<JsAppEditionService>();

  // Create helper to integrate angular best-practice
  var angularHelper = GetService<Angular>();

  // Show Angular either from dev (local) or from the compiled live/staging folders
  if (editionsHelper.CurrentEdition == "local")
  {
    @Html.Partial("./Angular Local Assets.cshtml", new { LocalDevServerPath = angularLocalDevServerPath, LocalDevFiles = angularLocalDevFiles, AngularAppTag = angularAppTag })
  }
  else
  {
    @Html.Raw(angularHelper.ImportAngularHtml(Text.Has(editions) ? editionsHelper.CurrentEdition : "", angularAppTag, angularAppPath))
  }

  // Show edition selector for host/super users only - you could also change this, to allow testers to see this
  if (MyUser.IsContentAdmin && Text.Has(editions))
  {
    @Html.Partial("../js-app-editions/Editions Bar.cshtml", new { Editions = editions })
  }
}
